const visibleProducts = products.slice(0, 6);
const extraProducts = products.slice(6);
---
<Base
  title="Dog Health Guides"
  description="Vet-reviewed dog health guides covering symptoms, prevention, and care."
>
  <Hero
    title="Dog Health Guides"
    subtitle="Recognize symptoms early and keep your dog healthy with vet-reviewed advice."
    ctaText="Browse Health Topics"
    ctaLink="#health-topics"
  />

  <section class="section" id="recommended-products">
    <div class="container">
      <div class="section-title">
        <h2>Recommended Health Products</h2>
        <p>Vet-favored supplements, ear care, parasite prevention, and more.</p>
      </div>

      <div class="grid grid-3" id="product-grid">
        {visibleProducts.map((p) => (
          <ProductBox
            title={p.title}
            description={p.description}
            link={p.link}
            rating={p.rating}
            price={p.price}
            badge={p.badge}
          />
        ))}
        {extraProducts.map((p) => (
          <div class="extra-product" style="display:none;">
            <ProductBox
              title={p.title}
              description={p.description}
              link={p.link}
              rating={p.rating}
              price={p.price}
              badge={p.badge}
            />
          </div>
        ))}
      </div>

      {extraProducts.length > 0 && (
        <div class="show-more-wrap">
          <button id="toggle-products" class="btn btn-primary">View All Products →</button>
        </div>
      )}
    </div>
  </section>

  <section class="section alt-bg" id="health-topics">
    <div class="container">
      <div class="section-title">
        <h2>Health Articles</h2>
        <p>{healthArticles.length} guide{healthArticles.length !== 1 ? "s" : ""} and counting.</p>
      </div>

      {healthArticles.length > 0 ? (
        <div class="grid grid-3">
          {healthArticles.map((entry) => (
            <ArticleCard
              title={entry.data.title}
              excerpt={entry.data.excerpt}
              link={`/health/${entry.id}`}
              category={entry.data.category}
              image={entry.data.image}
              date={entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">More health guides coming soon.</p>
      )}
    </div>
  </section>

  <Newsletter
    title="Stay Ahead of Health Issues"
    subtitle="Weekly tips on prevention, symptoms, and vet-approved care."
  />
</Base>

<script>
  const toggleBtn = document.getElementById("toggle-products");
  const extras = document.querySelectorAll(".extra-product");
  let expanded = false;

  toggleBtn?.addEventListener("click", () => {
    expanded = !expanded;
    extras.forEach((el) => {
      (el as HTMLElement).style.display = expanded ? "block" : "none";
    });
    toggleBtn.textContent = expanded ? "Show Less ↑" : "View All Products →";
  });
</script>

<style>
  .alt-bg { background: var(--bg-soft); }
  .empty-state { text-align: center; color: #9ca3af; padding: 24px 0; }
  .show-more-wrap {
    text-align: center;
    margin-top: 28px;
  }
</style>

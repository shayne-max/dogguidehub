---
import Base from "../layouts/Base.astro";
---
<Base
  title="Affiliate Disclosure"
  description="DogGuideHub affiliate disclosure — how we earn commissions through product and service links."
>
  <section class="section legal-page">
    <div class="container">
      <h1>Affiliate Disclosure</h1>
      <p class="updated">Last updated: June 2026</p>

      <p>
        DogGuideHub is a participant in various affiliate marketing programs, including but not limited
        to Amazon Associates, Chewy, and pet insurance partner programs. This means we may earn
        commissions on qualifying purchases or actions made through links on this Site, at no
        additional cost to you.
      </p>

      <h2>How This Works</h2>
      <p>
        When you click a product or service link on DogGuideHub and make a purchase or complete a
        signup, we may receive a small commission from the retailer or service provider. This helps
        support the operation of this Site and allows us to continue producing free, vet-reviewed
        content for dog owners.
      </p>

      <h2>Our Commitment to You</h2>
      <p>
        Our recommendations are based on independent research and editorial judgment. Affiliate
        relationships do not influence the accuracy or objectivity of our content. We only recommend
        products and services we believe provide genuine value to dog owners.
      </p>

      <h2>Identifying Affiliate Links</h2>
      <p>
        Affiliate links may appear within articles, product comparison boxes, and recommendation
        sections throughout the Site. Not all links on this Site are affiliate links.
      </p>

      <h2>Questions</h2>
      <p>
        If you have any questions about our affiliate relationships, please contact us at
        <a href="mailto:contact@dogguidehub.com">contact@dogguidehub.com</a>.
      </p>
    </div>
  </section>
</Base>

<style>
  .legal-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 20px;
  }
  .legal-page h1 { color: var(--primary-dark); }
  .legal-page h2 { margin-top: 32px; color: var(--primary-dark); font-size: 20px; }
  .legal-page p { color: var(--text-muted); }
  .legal-page a { color: var(--primary); font-weight: 600; }
  .updated { font-size: 13px; color: #9ca3af; }
</style>
---
export interface Props {
  title: string;
  description: string;
  image: string;
  link?: string;
}

const { title, description, image, link } = Astro.props as Props;
---
<div class="digital-card">
  <div class="digital-img">
    <img src={image} alt={title} loading="lazy" />
  </div>
  <div class="digital-body">
    <h3>{title}</h3>
    <p>{description}</p>
    {link ? (
      <a href={link} target="_blank" rel="nofollow sponsored noopener" class="btn btn-cta">
        View Product →
      </a>
    ) : (
      <span class="badge-soon">Coming soon</span>
    )}
  </div>
</div>

<style>
  .digital-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: #fff;
    box-shadow: var(--shadow);
    transition: box-shadow .2s ease, transform .2s ease;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .digital-card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }
  .digital-img {
    aspect-ratio: 3/2;
    background: var(--bg-soft);
  }
  .digital-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .digital-body {
    padding: 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .digital-body h3 {
    font-size: 16px;
    margin: 0 0 6px;
    color: var(--primary-dark);
  }
  .digital-body p {
    font-size: 14px;
    color: var(--text-muted);
    margin: 0 0 14px;
    flex: 1;
  }
  .badge-soon {
    align-self: flex-start;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--bg-soft);
    color: var(--text-muted);
  }
</style>

---
import { getCollection } from "astro:content";

const slidesRaw = await getCollection("carousel", ({ data }) => !data.draft);
const slides = slidesRaw.sort((a, b) => a.data.order - b.data.order);
---

{slides.length > 0 && (
  <section class="carousel">
    <div class="container">
      <div class="carousel-track">
        {slides.map((slide) => (
          <a href={slide.data.link} class="carousel-card">
            <img
              src={slide.data.image}
              alt={slide.data.title}
              loading="lazy"
              width="600"
              height="400"
            />
            <div class="carousel-overlay">
              <p class="carousel-title">{slide.data.title}</p>
              <p class="carousel-tagline">{slide.data.tagline} →</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .carousel {
    padding: 8px 0 40px;
  }

  .carousel-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 4px;
    scrollbar-width: thin;
  }

  .carousel-card {
    position: relative;
    flex: 0 0 300px;
    aspect-ratio: 3 / 2;
    border-radius: var(--radius);
    overflow: hidden;
    scroll-snap-align: start;
    box-shadow: var(--shadow);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .carousel-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  .carousel-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .carousel-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 16px 18px 14px;
    background: linear-gradient(
      to top,
      rgba(30, 58, 138, 0.92) 0%,
      rgba(30, 58, 138, 0.55) 55%,
      rgba(30, 58, 138, 0) 100%
    );
  }

  .carousel-title {
    margin: 0 0 4px;
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
  }

  .carousel-tagline {
    margin: 0;
    color: #e0f2fe;
    font-size: 13px;
    font-weight: 400;
  }

  @media (max-width: 640px) {
    .carousel-card {
      flex-basis: 260px;
    }
  }
</style>

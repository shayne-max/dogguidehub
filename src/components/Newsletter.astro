---
export interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Get Free Dog Care Tips",
  subtitle = "Join 10,000+ dog owners getting weekly vet-reviewed tips, food recall alerts, and product deals.",
} = Astro.props as Props;
---
<section class="newsletter">
  <div class="container newsletter-inner">
    <h2>{title}</h2>
    <p>{subtitle}</p>

    <form id="newsletter-form" class="newsletter-form" novalidate>
      <input
        type="email"
        name="email"
        id="newsletter-email"
        placeholder="you@email.com"
        required
        autocomplete="email"
      />
      <button type="submit" class="btn btn-cta" id="newsletter-btn">Subscribe →</button>
    </form>

    <p id="newsletter-message" class="newsletter-message" role="status"></p>
    <p class="privacy-note">No spam. Unsubscribe anytime.</p>
  </div>
</section>

<script>
  // ----------------------------------------------------------------------
  // Newsletter signup: writes to Supabase, then Supabase Edge Function /
  // DB webhook can push to MailerLite. Replace the placeholders below.
  // ----------------------------------------------------------------------
  const SUPABASE_URL = "https://ugdkpbinctkulimuxoem.supabase.co";
  const SUPABASE_ANON_KEY = "sb_publishable_NW935TWHhRXeH_BNiDQjlg_olnE1_fm";

  const form = document.getElementById("newsletter-form") as HTMLFormElement | null;
  const emailInput = document.getElementById("newsletter-email") as HTMLInputElement | null;
  const button = document.getElementById("newsletter-btn") as HTMLButtonElement | null;
  const message = document.getElementById("newsletter-message") as HTMLParagraphElement | null;

  function setMessage(text: string, isError = false) {
    if (!message) return;
    message.textContent = text;
    message.style.color = isError ? "#dc2626" : "#16a34a";
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = emailInput?.value.trim();

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setMessage("Please enter a valid email address.", true);
      return;
    }

    if (button) {
      button.disabled = true;
      button.textContent = "Subscribing...";
    }

    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/subscribers`, {
        method: "POST",
        headers: {
          apikey: SUPABASE_ANON_KEY,
          Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
          "Content-Type": "application/json",
          Prefer: "return=minimal,resolution=ignore-duplicates",
        },
        body: JSON.stringify({
          email,
          source: "website_newsletter",
          created_at: new Date().toISOString(),
        }),
      });

      if (!res.ok && res.status !== 409) {
        throw new Error(`Supabase error: ${res.status}`);
      }

      setMessage("🎉 You're subscribed! Check your inbox to confirm.");
      form.reset();
    } catch (err) {
      console.error(err);
      setMessage("Something went wrong. Please try again.", true);
    } finally {
      if (button) {
        button.disabled = false;
        button.textContent = "Subscribe →";
      }
    }
  });
</script>

<style>
  .newsletter {
    background: var(--primary-light);
    border-radius: var(--radius);
    margin: 40px auto;
    max-width: var(--max-width);
    padding: 48px 24px;
    text-align: center;
  }
  .newsletter-inner { max-width: 560px; margin: 0 auto; }
  .newsletter h2 { color: var(--primary-dark); }
  .newsletter-form {
    display: flex;
    gap: 10px;
    margin-top: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .newsletter-form input {
    flex: 1;
    min-width: 220px;
    padding: 13px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 15px;
  }
  .newsletter-form input:focus {
    outline: none;
    border-color: var(--primary);
  }
  .newsletter-message {
    min-height: 20px;
    margin-top: 14px;
    font-weight: 600;
    font-size: 14px;
  }
  .privacy-note {
    font-size: 13px;
    color: #6b7280;
    margin: 0;
  }
</style>
